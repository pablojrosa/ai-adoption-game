{
  "name": "ai-adoption-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server/dev.mjs",
    "dev:client": "vite",
    "dev:server": "node --no-warnings --watch server/server.mjs",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest",
    "spec:check": "node scripts/spec-check.mjs",
    "spec:list": "find specs -type f | sort",
    "spec:new": "node scripts/spec-new.mjs",
    "preview": "vite preview",
    "start": "node --no-warnings server/server.mjs"
  },
  "dependencies": {
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "^5.9.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  }
}
